{
  "name": "earth-and-home-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "wrangler d1 migrations apply earth-and-home-db --local",
    "dev": "next dev --turbopack -p 3010",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "npm": "pnpm",
    "analyze": "ANALYZE=true next build --webpack",
    "lighthouse": "lighthouse http://localhost:3010 --output-path=./lighthouse/localhost_3010-$(date +%Y%m%dT%H%M%S).html --save-assets --view",
    "perf:build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "ci:build": "bash scripts/stub-resvg-wasm.sh stub && opennextjs-cloudflare build",
    "deploy": "bash scripts/stub-resvg-wasm.sh stub && opennextjs-cloudflare build && opennextjs-cloudflare deploy && bash scripts/stub-resvg-wasm.sh restore",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "auth:generate": "pnpm exec better-auth generate --config better-auth.config.ts --output src/db/schema/auth-schema.ts -y",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate:local": "wrangler d1 migrations apply earth-and-home-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply earth-and-home-db --remote",
    "setup:prod-secrets": "node scripts/set-production-secrets.js",
    "list:prod-secrets": "node scripts/list-production-secrets.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@opennextjs/cloudflare": "^1.18.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.85.3",
    "babel-plugin-react-compiler": "1.0.0",
    "better-auth": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.539.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "nuqs": "^2.4.3",
    "postcss": "^8.5.6",
    "react": "^19",
    "react-day-picker": "^9.8.1",
    "react-dom": "^19",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.62.0",
    "react-hook-form-persist": "^3.0.0",
    "react-hotkeys-hook": "^5.1.0",
    "react-responsive-pagination": "^2.11.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@cloudflare/workers-types": "^4.20260408.1",
    "@libsql/client": "^0.17.2",
    "@next/bundle-analyzer": "^16.2.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "daisyui": "^5.0.54",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "react-grab": "^0.1.31",
    "tailwindcss": "^4",
    "tsx": "^4.20.4",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5",
    "wrangler": "^4.81.0"
  }
}
